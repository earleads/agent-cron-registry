# Copy this file to .env and fill in your own values. Never commit .env.

# A Notion integration token. Create one at https://www.notion.so/my-integrations
# (Internal Integration, no special capabilities needed beyond read/write content).
NOTION_API_TOKEN=

# The ID of your "Scheduled Jobs" database. Leave blank until you've run
# scripts/setup-notion-db.sh once — it prints this value for you.
NOTION_REGISTRY_DB_ID=
